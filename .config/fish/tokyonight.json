{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "blocks": [
    {
      "alignment": "left",
      "segments": [
        {
          "background": "#7aa2f7",
          "foreground": "#1a1b26",
          "leading_diamond": "",
          "style": "diamond",
          "template": " {{ .Path }} ",
          "type": "path",
          "properties": {
            "style": "folder"
          }
        },
        {
          "background": "#bb9af7",
          "foreground": "#1a1b26",
          "powerline_symbol": "",
          "style": "powerline",
          "template": " {{ .HEAD }}{{ if or (.Working.Changed) (.Staging.Changed) }}*{{ end }} <#1a1b26></> ",
          "type": "git"
        },
        {
          "foreground": "#7aa2f7",
          "style": "plain",
          "template": " ❯ ",
          "type": "text"
        }
      ],
      "type": "prompt"
    }
  ],
  "transient_prompt": {
    "background": "transparent",
    "foreground": "#7aa2f7",
    "template": "❯ "
  },
  "final_space": true,
  "version": 2
}
